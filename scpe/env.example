# 复制为 env.local 后填入密钥: cp env.example env.local
export GEMINI_API_KEY=""
export DASHSCOPE_API_KEY=""

# ACE / Wan 文案语言: cn | en
#   ace_i2v_official3 → ace_prompts_{lang}.json, playbook_seed_{lang}.json, wan22_wrap_{lang}.json
#   ace_v2f_qa2       → qa2_prompts_{lang}.json
export ACE_LANG="${ACE_LANG:-cn}"

# 数据根目录（含标注 JSON / 原图 / epoch_0 视频）
export DATA_ROOT="${DATA_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../data" && pwd)}"

# 本地 Wan2.2 I2V A14B（见 run_wan22_local_a14b.sh）
export WAN22_REPO="${WAN22_REPO:-$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../Wan2.2" && pwd)}"
export WAN22_CKPT_DIR="${WAN22_CKPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../Wan2.2-I2V-A14B" && pwd)}"
# WAN22_DEVICE=cuda|npu
# WAN22_RUN_MODE=inprocess|subprocess
# WAN22_LAUNCHER=python|torchrun
# WAN22_NPROC=8
# WAN22_SUBPROCESS_EXTRA="--dit_fsdp --t5_fsdp --cfg_size 2 --ulysses_size 4 --vae_parallel"

# 可选：代理
# export HTTP_PROXY="http://127.0.0.1:7890"
# export HTTPS_PROXY="$HTTP_PROXY"
